// Prisma schema — SQLite for the client demo.
// To migrate to Firebase later, see README "Migrating to Firebase".

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id          String      @id @default(cuid())
  name        String
  slug        String      @unique
  weight      String
  price       Int // stored in rupees (whole number)
  mrp         Int? // optional strike-through price
  description String
  image       String
  category    String      @default("Pickle")
  featured    Boolean     @default(false)
  inStock     Boolean     @default(true)
  spiceLevel  Int         @default(3) // 1-5
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  orderItems  OrderItem[]
}

model Order {
  id           String      @id @default(cuid())
  orderNumber  String      @unique
  customerName String
  phone        String
  address      String
  city         String
  state        String
  pincode      String
  notes        String?
  total        Int
  status       String      @default("Pending") // Pending|Confirmed|Packed|Shipped|Delivered
  items        OrderItem[]
  customer     Customer?   @relation(fields: [customerId], references: [id])
  customerId   String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model OrderItem {
  id        String  @id @default(cuid())
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId   String
  product   Product? @relation(fields: [productId], references: [id])
  productId String?
  name      String
  weight    String
  price     Int
  quantity  Int
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  phone     String   @unique
  orders    Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String // bcrypt hash
  name      String   @default("Admin")
  createdAt DateTime @default(now())
}

model Setting {
  key   String @id
  value String
}
